---
/*
  Newsletter signup.

  A static site can't store emails or send mail itself, so this form POSTs to a
  third-party newsletter service. Pick one with "RSS-to-email" so new posts send
  automatically from your /rss.xml feed:
    • Buttondown   — https://buttondown.com   (indie-friendly, free tier)
    • Kit (ConvertKit), Mailchimp, EmailOctopus, Beehiiv — all support RSS campaigns

  Then replace the action URL below with your provider's embed endpoint.
  (Example shown is Buttondown's — swap USERNAME for your account.)
*/
const action = 'https://buttondown.com/api/emails/embed-subscribe/USERNAME';
---

<section class="section newsletter">
  <h2>Newsletter</h2>
  <p class="news-lead">
    Get new Ronny Thoughts in your inbox — no need to keep checking back.
  </p>

  <form class="news-form" action={action} method="post" target="_blank">
    <input
      class="news-input"
      type="email"
      name="email"
      placeholder="you@email.com"
      aria-label="Email address"
      required
    />
    <button class="news-btn" type="submit">Subscribe</button>
  </form>

  <p class="news-rss">Prefer RSS? <a href="/rss.xml">Subscribe to the feed ↗</a></p>
</section>

<style>
  .newsletter { display: flex; flex-direction: column; gap: 10px; }
  .news-lead { color: var(--ink-soft); font-size: 15.5px; line-height: 1.5; }

  .news-form { display: flex; gap: 8px; margin-top: 4px; flex-wrap: wrap; }
  .news-input {
    flex: 1;
    min-width: 200px;
    font: inherit;
    color: var(--ink);
    background: var(--card-soft);
    border: 1.5px solid var(--line);
    padding: 11px 14px;
  }
  .news-input:focus { outline: 2px solid var(--accent); outline-offset: -1px; }
  .news-btn {
    font: inherit;
    font-weight: 600;
    color: #fff;
    background: var(--accent);
    border: 1.5px solid var(--line);
    padding: 11px 18px;
    cursor: pointer;
  }
  .news-btn:hover { filter: brightness(0.95); }

  .news-rss { font-size: 14px; color: var(--ink-soft); margin-top: 2px; }
  .news-rss a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
</style>
