---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

const businesses = await getCollection('businesses');
const thumbs = ['g-green', 'g-blue', 'g-pink', 'g-orange'];
---

<PageLayout title="Businesses — LaRon" back="/" backLabel="← Back">
  <section class="hero hero--business">
    <span class="hero-eyebrow">Featured</span>
    <h1>Businesses</h1>
    <p>Things I'm building and running on my own.</p>
  </section>

  <section class="section">
    <h2>My businesses</h2>
    {businesses.map((b, i) => (
      <a class="entry" href={`/businesses/${b.id}`}>
        <div class={`entry-thumb ${thumbs[i % thumbs.length]}`}></div>
        <div class="entry-body">
          <div class="entry-top">
            <h3>{b.data.title}</h3>
            {b.data.employees && (
              <span class="entry-date">{b.data.employees} {b.data.employees === 1 ? 'employee' : 'employees'}</span>
            )}
          </div>
          <p>{b.data.description}</p>
          {b.data.profit && <span class="tag">Monthly profit: {b.data.profit}</span>}
        </div>
      </a>
    ))}
  </section>
</PageLayout>
