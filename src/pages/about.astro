---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="About — LaRon" back="/" backLabel="← Back">
  <section class="hero hero--about">
    <span class="app-ico app-ico--about">
      <svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/>
      </svg>
    </span>
    <h1>More about me</h1>
    <p>I'm LaRon — 28, going through life and figuring it out as I go.</p>
  </section>

  <section class="section">
    <h2>The short version</h2>
    <p style="font-size:18px;line-height:1.6;color:var(--ink);max-width:60ch;">
      This is my corner of the internet — all about me. I like building things on
      the side, mostly small web projects with Astro, and running a couple of
      one-person businesses. When I'm not building, I'm writing the occasional
      Ronny Thought about life and how quickly it passes us by.
    </p>
  </section>

  <section class="section">
    <h2>Around here</h2>
    <ul class="timeline">
      <li><span class="yr">Projects</span><span class="role">Astro Nano <span>· TO_DO_ME</span></span></li>
      <li><span class="yr">Businesses</span><span class="role">4TheLazy <span>· A5 Design</span></span></li>
      <li><span class="yr">Writing</span><span class="role">Ronny Thoughts <span>· on life &amp; building</span></span></li>
    </ul>
  </section>
</PageLayout>
