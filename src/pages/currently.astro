---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Currently into — LaRon" back="/" backLabel="← Back">
  <section class="hero hero--current">
    <span class="app-ico app-ico--current">
      <svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 3l2.2 5.5L20 10l-4.5 3.4L17 19l-5-3-5 3 1.5-5.6L4 10l5.8-1.5z"/>
      </svg>
    </span>
    <span class="hero-eyebrow">Currently into</span>
    <h1>Coming soon</h1>
    <p>A spot for whatever I'm into lately — books, tools, games, rabbit holes. Haven't filled it in yet.</p>
  </section>

  <section class="section">
    <h2>On the list</h2>
    <p style="font-size:18px;line-height:1.6;color:var(--ink-soft);max-width:60ch;">
      Nothing here yet. This is where I'll jot down what's caught my attention
      recently — check back soon.
    </p>
  </section>
</PageLayout>
