---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

const items = await getCollection('currently');
---

<PageLayout title="Currently into — LaRon" back="/" backLabel="← Back">
  <section class="hero hero--current">
    <span class="app-ico app-ico--current">
      <svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 3l2.2 5.5L20 10l-4.5 3.4L17 19l-5-3-5 3 1.5-5.6L4 10l5.8-1.5z"/>
      </svg>
    </span>
    <span class="hero-eyebrow">Currently into</span>
    <h1>Right now</h1>
    <p>Products, tools and things I'm using, playing and watching at the moment.</p>
  </section>

  <div class="now-grid">
    {items.map((item) => {
      const Tag = item.data.url ? 'a' : 'div';
      return (
        <Tag
          class="now-card"
          href={item.data.url}
          target={item.data.url ? '_blank' : undefined}
          rel={item.data.url ? 'noopener' : undefined}
        >
          {item.data.category && <span class="now-cat">{item.data.category}</span>}
          <h3>{item.data.title}</h3>
          <p>{item.data.description}</p>
          {item.data.url && <span class="app-arrow" aria-hidden="true">↗</span>}
        </Tag>
      );
    })}
  </div>
</PageLayout>
