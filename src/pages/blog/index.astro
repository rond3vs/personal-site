---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<PageLayout title="Ronny Thoughts — LaRon" back="/" backLabel="← Back">
  <section class="hero hero--blog">
    <span class="app-ico app-ico--blog">
      <svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 4h12l4 4v12H4z"/><path d="M8 9h6M8 13h8M8 17h5"/>
      </svg>
    </span>
    <h1>Ronny Thoughts</h1>
    <p>Reflections on life and building — written in the open as I figure things out.</p>
  </section>

  <section class="section">
    <h2>{posts.length} {posts.length === 1 ? 'post' : 'posts'}</h2>
    {posts.map((post) => (
      <a class="entry" href={`/blog/${post.id}`}>
        <div class="entry-body">
          <div class="entry-top">
            <h3>{post.data.title}</h3>
            <span class="entry-date">{post.data.date.getFullYear()}</span>
          </div>
          <p>{post.data.description}</p>
        </div>
      </a>
    ))}
  </section>
</PageLayout>
