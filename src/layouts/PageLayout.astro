---
import Base from './Base.astro';
import BrandMark from '../components/BrandMark.astro';

interface Props {
  title: string;
  description?: string;
  back?: string;
  backLabel?: string;
}
const { title, description, back = '/', backLabel = '← Back' } = Astro.props;
---

<Base title={title} description={description}>
  <div class="page-shell">
    <header class="bar bar--main">
      <a class="brand" href="/" aria-label="Home"><BrandMark /></a>
      <a class="back" href={back}>{backLabel}</a>
    </header>

    <main class="page-wrap">
      <slot />
    </main>
  </div>
</Base>
